-- === TAB CONTENT ===
local function createTabContent()
    local frame = Instance.new("ScrollingFrame")
    frame.Size = UDim2.new(1, -12, 1, -12)
    frame.Position = UDim2.new(0, 6, 0, 6)
    frame.BackgroundTransparency = 1
    frame.ScrollBarThickness = 3
    frame.ScrollBarImageColor3 = Color3.fromRGB(90, 90, 90)
    frame.Visible = false
    frame.CanvasSize = UDim2.new(0, 0, 0, 0)
    frame.Parent = ContentArea

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 4)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = frame
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        frame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end)

    return frame, layout
end

local Tab1Content, Tab1Layout = createTabContent() -- Arsenal
local Tab2Content, Tab2Layout = createTabContent() -- Scripts  
local Tab3Content, Tab3Layout = createTabContent() -- Humanoid
local Tab5Content, Tab5Layout = createTabContent() -- Patch

-- === MAKE SIDE TAB BUTTONS ===
local ActiveTabButton = nil
local function makeTab(name, content)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -12, 0, 28)
    btn.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(55, 55, 55)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 13
    btn.AutoButtonColor = false
    btn.TextWrapped = true
    btn.Parent = SidePanel

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 4)
    padding.PaddingRight = UDim.new(0, 4)
    padding.PaddingTop = UDim.new(0, 2)
    padding.PaddingBottom = UDim.new(0, 2)
    padding.Parent = btn

    btn.MouseButton1Click:Connect(function()
        for _, t in pairs({Tab1Content, Tab2Content, Tab3Content, Tab5Content}) do
            t.Visible = false
        end
        content.Visible = true
        CurrentTab = content

        if ActiveTabButton then
            ActiveTabButton.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
            ActiveTabButton.TextColor3 = Color3.fromRGB(220, 220, 220)
        end
        ActiveTabButton = btn
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    return btn
end

makeTab("Arsenal", Tab1Content)
makeTab("Scripts", Tab2Content)
makeTab("Humanoid", Tab3Content)
makeTab("Patch", Tab5Content)

