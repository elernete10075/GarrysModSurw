-- === CREATE BUTTONS ===
local ButtonLists = { Tab1 = {}, Tab2 = {}, Tab3 = {}, Tab5 = {} }

local function createButton(scriptData)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -12, 0, 38)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(60, 60, 60)
    btn.Text = scriptData.Name
    btn.TextColor3 = Color3.fromRGB(230, 230, 230)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.AutoButtonColor = false
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = scriptData.Tab

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 10)
    padding.PaddingTop = UDim.new(0, 4)
    padding.PaddingBottom = UDim.new(0, 4)
    padding.Parent = btn

    btn.MouseButton1Click:Connect(function()
        toggleScript(scriptData, btn)
    end)

    return btn
end

-- Создаем слайдеры
createSlider(Tab3Content, "WalkSpeed", 16, 200, 16)
createSlider(Tab3Content, "JumpPower", 50, 200, 50)

-- Создаем все кнопки
for _, s in ipairs(Scripts) do
    local btn = createButton(s)
    table.insert(
        s.Tab == Tab1Content and ButtonLists.Tab1 or
        s.Tab == Tab2Content and ButtonLists.Tab2 or
        s.Tab == Tab3Content and ButtonLists.Tab3 or
        ButtonLists.Tab5, btn
    )
end

-- === SEARCH FUNCTION ===
local function updateSearch()
    local query = SearchBox.Text:lower()
    local list = CurrentTab == Tab1Content and ButtonLists.Tab1 or
                 CurrentTab == Tab2Content and ButtonLists.Tab2 or
                 CurrentTab == Tab3Content and ButtonLists.Tab3 or
                 ButtonLists.Tab5
    for _, btn in ipairs(list or {}) do
        btn.Visible = query == "" or btn.Text:lower():find(query) ~= nil
    end
end
SearchBox:GetPropertyChangedSignal("Text"):Connect(updateSearch)

-- === STARTUP ===
Tab1Content.Visible = true
CurrentTab = Tab1Content

task.wait(0.5)
if Tab1Content.UIListLayout then
    Tab1Content.CanvasSize = UDim2.new(0, 0, 0, Tab1Content.UIListLayout.AbsoluteContentSize.Y + 20)
end

